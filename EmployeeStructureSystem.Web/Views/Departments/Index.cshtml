@model IReadOnlyList<DepartmentListItemViewModel>

@{
    ViewData["Title"] = "Departments";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Departments</p>
        <h1 class="h2 mb-2">Departments</h1>
        <p class="section-copy mb-0">Create, rename, and remove departments.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">New Department</a>
    </div>
</section>

<section class="content-card">
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <h2 class="h4">No departments yet</h2>
            <p class="mb-3">Create the first department to start building the organization structure.</p>
            <a class="btn btn-primary" asp-action="Create">Create Department</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Description</th>
                        <th>Employees</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var department in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@department.Name</div>
                        </td>
                        <td class="table-muted">@(string.IsNullOrWhiteSpace(department.Description) ? "No description" : department.Description)</td>
                        <td>@department.EmployeeCount</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@department.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-dark" asp-action="Delete" asp-route-id="@department.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>