@model EmployeeIndexViewModel

@{
    ViewData["Title"] = "Employees";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Employees</p>
        <h1 class="h2 mb-2">Employees</h1>
        <p class="section-copy mb-0">Create, update, and remove employees while keeping department and position assignments visible.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">New Employee</a>
    </div>
</section>

<section class="content-card">
    <form method="get" class="row g-3 align-items-end mb-4">
        <div class="col-md-4">
            <label asp-for="DepartmentId" class="form-label">Department</label>
            <select asp-for="DepartmentId" asp-items="Model.DepartmentOptions" class="form-select"></select>
        </div>
        <div class="col-md-4">
            <label asp-for="PositionId" class="form-label">Position</label>
            <select asp-for="PositionId" asp-items="Model.PositionOptions" class="form-select"></select>
        </div>
        <div class="col-md-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Apply filters</button>
            <a class="btn btn-outline-dark" asp-action="Index">Clear</a>
        </div>
    </form>

    @if (Model.Employees.Count == 0)
    {
        <div class="empty-state">
            <h2 class="h4">No employees found</h2>
            <p class="mb-3">
                @(Model.DepartmentId.HasValue || Model.PositionId.HasValue
                    ? "No employees match the selected department and position filters."
                    : "Add the first employee and assign a department and position to start building the roster.")
            </p>
            @if (Model.DepartmentId.HasValue || Model.PositionId.HasValue)
            {
                <a class="btn btn-outline-dark" asp-action="Index">Clear filters</a>
            }
            else
            {
                <a class="btn btn-primary" asp-action="Create">Create Employee</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Position</th>
                        <th>Salary</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var employee in Model.Employees)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@employee.FirstName @employee.LastName</div>
                        </td>
                        <td class="table-muted">@(string.IsNullOrWhiteSpace(employee.Email) ? "No email" : employee.Email)</td>
                        <td>@employee.DepartmentName</td>
                        <td>@employee.PositionTitle</td>
                        <td>@employee.Salary.ToString("C")</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@employee.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-dark" asp-action="Delete" asp-route-id="@employee.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>