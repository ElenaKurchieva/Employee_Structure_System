@model IReadOnlyList<PositionListItemViewModel>

@{
    ViewData["Title"] = "Positions";
}

<section class="page-header">
    <div>
        <p class="eyebrow">Positions</p>
        <h1 class="h2 mb-2">Position catalog</h1>
        <p class="section-copy mb-0">Maintain the list of available roles without embedding business logic in the UI.</p>
    </div>
    <div class="page-actions">
        <a class="btn btn-primary" asp-action="Create">New Position</a>
    </div>
</section>

<section class="content-card">
    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <h2 class="h4">No positions yet</h2>
            <p class="mb-3">Create the first position to prepare for future employee assignment flows.</p>
            <a class="btn btn-primary" asp-action="Create">Create Position</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Employees</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var position in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@position.Title</div>
                        </td>
                        <td class="table-muted">@(string.IsNullOrWhiteSpace(position.Description) ? "No description" : position.Description)</td>
                        <td>@position.EmployeeCount</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@position.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-dark" asp-action="Delete" asp-route-id="@position.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>